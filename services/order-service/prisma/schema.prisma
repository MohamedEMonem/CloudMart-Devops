// ──────────────────────────────────────────────
// Order Management Service — Prisma Schema
// Phase 3: Saga + Transactional Outbox
// ──────────────────────────────────────────────

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
}

model Order {
  id              String      @id @default(uuid())
  userId          String      @map("user_id")
  status          OrderStatus @default(PENDING)
  totalAmount     Decimal     @map("total_amount") @db.Decimal(12, 2)
  shippingAddress Json        @map("shipping_address")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  items        OrderItem[]
  vendorSplits VendorOrderSplit[]

  @@index([userId])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id          String  @id @default(uuid())
  orderId     String  @map("order_id")
  vendorId    String  @map("vendor_id")
  productId   String  @map("product_id")
  productName String  @map("product_name")
  quantity    Int
  unitPrice   Decimal @map("unit_price") @db.Decimal(12, 2)

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([vendorId])
  @@map("order_items")
}

model VendorOrderSplit {
  id               String  @id @default(uuid())
  orderId          String  @map("order_id")
  vendorId         String  @map("vendor_id")
  subtotal         Decimal @db.Decimal(12, 2)
  commissionRate   Decimal @map("commission_rate") @db.Decimal(4, 3)
  commissionAmount Decimal @map("commission_amount") @db.Decimal(12, 2)
  vendorPayout     Decimal @map("vendor_payout") @db.Decimal(12, 2)
  status           String  @default("PENDING")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([orderId, vendorId])
  @@index([vendorId])
  @@map("vendor_order_splits")
}

// ──────────────────────────────────────────────
// Transactional Outbox
//
// Solves the dual-write problem:
//   1. Order + Outbox row are persisted in the
//      SAME Prisma $transaction (atomic).
//   2. A background relay reads un-sent rows
//      and publishes them to RabbitMQ.
//   3. After successful publish, marks the row
//      as 'SENT'.
//
// If the app crashes between DB commit and RMQ
// publish, the relay will pick up the unsent row
// on the next polling cycle — no event is lost.
// ──────────────────────────────────────────────
model OutboxMessage {
  id          String   @id @default(uuid())
  eventType   String   @map("event_type")     // e.g. 'order.created'
  payload     Json                             // serialized event body
  status      String   @default("PENDING")     // PENDING | SENT | FAILED
  retryCount  Int      @default(0) @map("retry_count")
  createdAt   DateTime @default(now()) @map("created_at")
  processedAt DateTime? @map("processed_at")

  @@index([status])
  @@index([createdAt])
  @@map("outbox_messages")
}
