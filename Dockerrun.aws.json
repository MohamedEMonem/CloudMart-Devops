{
  "AWSEBDockerrunVersion": 2,
  "containerDefinitions": [
     {
      "name": "backend",
      "image": "marwanmw/cloudmart-backend:latest",
      "essential": true,
      "memory": 256,
      "portMappings": [
        {
          "hostPort": 5000,
          "containerPort": 5000
        }
      ]
    },
    {
      "name": "frontend",
      "image": "marwanmw/cloudmart-frontend:latest",
      "essential": true,
      "memory": 256,
      "portMappings": [
        {
          "hostPort": 80,
          "containerPort": 80
        }
      ],
      "links": [
        "backend"
      ]
    }
   
  ]
}